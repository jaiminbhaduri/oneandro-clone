# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=oneandro
POSTGRES_PASSWORD=change-me-in-local-env
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Logical databases provisioned by infra/postgres/init/01-databases.sql
POSTGRES_USERS_DB=users_db
POSTGRES_LEADS_DB=leads_db
POSTGRES_AI_DB=ai_db

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-in-local-env

# ── Kafka (KRaft, single broker for local dev) ────────────────────────────────
KAFKA_BROKER=kafka:9092
KAFKA_CLIENT_ID=oneandro-local
KAFKA_TOPIC_LEAD_STATUS_EVENTS=lead-status-events
KAFKA_TOPIC_USER_EVENTS=user-events

# ── JWT / Auth ──────────────────────────────────────────────────────────────
# Only an access-token secret: refresh tokens are opaque random secrets
# (hashed + stored server-side for rotation/revocation), never JWTs — see
# apps/user-service/src/auth/token.service.ts.
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_DOMAIN=localhost
CORS_ORIGINS=http://localhost:3000
SWAGGER_ENABLED=true

# ── Rate limiting (Redis sliding window, enforced in api-gateway) ───────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX_REQUESTS=5

# ── AI Orchestrator ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-replace-me
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
COHERE_API_KEY=replace-me
COHERE_RERANK_MODEL=rerank-v3.5
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__replace-me
LANGCHAIN_PROJECT=oneandro-clone-dev
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# Tier 1 semantic cache (Redis, brute-force cosine similarity — see
# apps/ai-orchestrator/src/tier1-qa/semantic-cache/redis-semantic-cache.service.ts)
SEMANTIC_CACHE_TTL_SECONDS=86400
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_MAX_CANDIDATES=500
# ai-orchestrator calls lead-service directly (HTTP, forwarding the
# caller's own token) to fetch lead facts — it never touches leads_db.
LEAD_SERVICE_URL=http://lead-service-1:3002

# ── Lead Service — KYC document storage ──────────────────────────────────────
KYC_STORAGE_DIR=/app/apps/lead-service/storage/kyc
KYC_MAX_FILE_SIZE_BYTES=10485760

# ── Banking Adapter Mock / Notifications ─────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM_ADDRESS=notifications@oneandro.local
# Simulated partner-bank processing latency for BANK_HANDOFF — see
# apps/banking-adapter-mock/src/handoff/handoff.service.ts
HANDOFF_MIN_DELAY_MS=3000
HANDOFF_MAX_DELAY_MS=8000

# ── Dev tools ─────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@oneandro.local
PGADMIN_DEFAULT_PASSWORD=change-me-in-local-env
